# AWT 환경변수 템플릿
# 이 파일을 .env로 복사 후 값을 채우세요: Copy-Item .env.example .env

# ── LLM Provider 선택 (D48) ─────────────────────────────────────────────
# 선택지: anthropic | openai | google
# 기본값: anthropic
LLM_PROVIDER=anthropic

# ── Provider별 API 키 (선택한 provider의 키만 필수) ─────────────────────
# Anthropic Claude (claude-* 모델 사용 시)
ANTHROPIC_API_KEY=sk-ant-여기에입력

# OpenAI GPT (gpt-*, o1-*, o3-* 모델 사용 시)
OPENAI_API_KEY=sk-여기에입력

# Google Gemini (gemini-* 모델 사용 시)
GOOGLE_API_KEY=AIza여기에입력

# ── PostgreSQL AWT 인증 DB ───────────────────────────────────────────────
AWT_DB_HOST=localhost
AWT_DB_PORT=5432
AWT_DB_NAME=awt
AWT_DB_USER=awt_user
AWT_DB_PASSWORD=changeme

# ── 선택 설정 ────────────────────────────────────────────────────────────
# LLM 캐시 비활성화 (재실험 시)
# AWT_NO_CACHE=1

# 로그 레벨
# AWT_LOG_LEVEL=INFO
